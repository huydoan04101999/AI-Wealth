{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "username", "role", "status", "createdAt"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "User API keys and agent configurations",
      "type": "object",
      "properties": {
        "openRouterApiKey": { "type": "string" },
        "groqApiKey": { "type": "string" },
        "tavilyApiKey": { "type": "string" },
        "exchangeRate": { "type": "number" },
        "currency": { "type": "string", "enum": ["USD", "VND"] },
        "agents": { "type": "array", "description": "List of agent configurations" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/settings/config": {
      "schema": { "$ref": "#/entities/UserSettings" },
      "description": "User application settings"
    }
  }
}
